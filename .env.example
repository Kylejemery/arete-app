# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=https://arete-app-production.up.railway.app

# Claude API key is now on the server - see server/.env.example
# EXPO_PUBLIC_CLAUDE_API_KEY=  <-- no longer needed in the app

# Supabase
EXPO_PUBLIC_SUPABASE_URL=your_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
